# =============================================================================
# EventOps — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# TLS / Keystore files (must be provisioned per deployment, never committed)
# ---------------------------------------------------------------------------
backend/src/main/resources/keystore/*.p12
backend/src/main/resources/keystore/*.jks
backend/src/main/resources/keystore/*.pfx

# ---------------------------------------------------------------------------
# Environment variable files (contain secrets)
# ---------------------------------------------------------------------------
.env
.env.local
frontend/.env.local
frontend/.env.*.local

# ---------------------------------------------------------------------------
# Maven build output
# ---------------------------------------------------------------------------
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar

# ---------------------------------------------------------------------------
# Node / npm build output
# ---------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/coverage/
frontend/playwright-report/
frontend/test-results/
frontend/.playwright/

# ---------------------------------------------------------------------------
# Java / IDE artifacts
# ---------------------------------------------------------------------------
*.class
*.jar
*.war
*.ear
*.log
*.orig

# IDE project files
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------------------------------------------------------------------------
# OS artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# JaCoCo coverage (generated, not source)
# ---------------------------------------------------------------------------
backend/target/site/

# ---------------------------------------------------------------------------
# Docker local overrides
# ---------------------------------------------------------------------------
docker-compose.override.yml
