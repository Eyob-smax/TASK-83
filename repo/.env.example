# =============================================================================
# EventOps — Environment Variable Reference
#
# Copy this file to .env and edit the values before running docker compose.
# Variables marked [REQUIRED] must be set; all others have safe defaults.
#
# Usage:
#   cp .env.example .env
#   # Edit .env to set required values and any overrides
#   docker compose up --build
# =============================================================================

# -----------------------------------------------------------------------------
# Database — MySQL 8.x
# -----------------------------------------------------------------------------

# [REQUIRED] MySQL root password (used by the MySQL container at first init).
# Must be replaced with a strong random value before first boot.
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# Application database name, user, and password.
# [REQUIRED] DB_PASSWORD must be replaced with a strong random value before
# first boot. Do not use the placeholder in any environment.
DB_NAME=eventops
DB_USERNAME=eventops
DB_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD

# MySQL external port (host-side; container always listens on 3306 internally)
MYSQL_PORT=3306

# -----------------------------------------------------------------------------
# Backend — Spring Boot / Server
# -----------------------------------------------------------------------------

# Spring profile to activate.
#   dev  — SSL off, DDL auto-update, signature verification off, verbose logging
#   (none) — production defaults (SSL on, DDL validate, signature on)
SPRING_PROFILES_ACTIVE=

# External port for the backend container (maps to internal SERVER_PORT 8443)
BACKEND_PORT=8443

# Internal server port — must match EXPOSE in backend/Dockerfile and the
# nginx proxy_pass target in frontend/nginx.conf.
# Do NOT change unless you also update Dockerfile and nginx.conf.
SERVER_PORT=8443

# -----------------------------------------------------------------------------
# Backend — TLS / HTTPS
# -----------------------------------------------------------------------------

# Set to true for HTTPS. Requires a provisioned keystore; see
# backend/src/main/resources/keystore/README.md for setup steps.
# When false, backend serves plain HTTP on SERVER_PORT.
SSL_ENABLED=true

# Path to PKCS12 keystore (classpath or absolute filesystem path).
# Only required when SSL_ENABLED=true.
# SSL_KEYSTORE=classpath:keystore/dev-keystore.p12
# SSL_KEYSTORE_PASSWORD=changeit

# -----------------------------------------------------------------------------
# Backend — Security
# -----------------------------------------------------------------------------

# [REQUIRED] AES-256 encryption key for sensitive fields at rest.
# Must be a strong random value in production. The application will refuse to
# start if this value is left blank or weak for the target environment.
ENCRYPTION_SECRET_KEY=replace-with-a-strong-secret

# Rate limiting (requests per minute per client)
# RATE_LIMIT_RPM=60

# Login throttle
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# HMAC-SHA256 request signature verification (enabled=true in production)
# SIGNATURE_ENABLED=true

# Optional backend fallback secret for non-session clients when
# SIGNATURE_ENABLED=true. Browser clients use a server-issued per-session
# signature token and should not bundle shared secrets.
# SIGNATURE_SECRET_KEY=replace-with-a-strong-signing-secret

# -----------------------------------------------------------------------------
# Backend — CORS
# -----------------------------------------------------------------------------

# Comma-separated list of origins allowed to make cross-origin API requests.
# In the standard docker-compose deployment, all browser requests flow through
# the nginx proxy (same-origin), so this setting only affects direct API
# access. Adjust for development workstations on the local network.
# CORS_ALLOWED_ORIGINS=http://localhost:443,http://localhost:5173,http://localhost

# -----------------------------------------------------------------------------
# Backend — Data Paths (mapped to named Docker volumes by default)
# -----------------------------------------------------------------------------

# Backup target directory inside the backend container.
# Mapped to the 'backup-data' named volume in docker-compose.yml.
BACKUP_PATH=/var/eventops/backups

# Export storage directory inside the backend container.
EXPORT_PATH=/var/eventops/exports

# Shared-folder import source root (badge CSVs and other drops).
SHARED_FOLDER_PATH=/var/eventops/shared

# Attachment upload storage directory.
ATTACHMENT_PATH=/var/eventops/attachments

# Maximum attachment upload size in MB.
# ATTACHMENT_MAX_SIZE=50

# -----------------------------------------------------------------------------
# Backend — Operational
# -----------------------------------------------------------------------------

# Enable/disable nightly backup job (cron: 2 AM daily)
# BACKUP_ENABLED=true

# Import concurrency cap (max simultaneous crawl workers)
# IMPORT_CONCURRENCY=3

# Import per-job timeout in seconds
# IMPORT_TIMEOUT=30

# Import circuit-breaker failure threshold
# IMPORT_CB_THRESHOLD=10

# Export watermark (set false to disable watermarks on exports — not recommended)
# WATERMARK_ENABLED=true

# Log verbosity for com.eventops packages
# LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend — nginx
# -----------------------------------------------------------------------------

# External port for the frontend container (maps to internal nginx port 80).
# The frontend is served over plain HTTP unless you place a TLS-terminating
# proxy in front of the nginx container.
FRONTEND_PORT=443


